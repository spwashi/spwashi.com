^["intent"]{
 ~#goal: "Normalize the authored HTML semantics across as many routes as practical, then let the runtime infer more of the repeated region bookkeeping instead of requiring every page to hand-author it."
 ~#taste: "clarity and layering: the site should keep its rich semantic language without making every HTML page carry an exhausting metadata ledger."
}

