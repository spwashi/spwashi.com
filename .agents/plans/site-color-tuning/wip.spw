}

^["recursive_improvement"]{
 loop: [
  "? reread the token and shared surface layers before blaming any single route",
  "< move the base palette first so route tuning becomes smaller and more honest",
  "$ keep operator families distinct even while narrowing the overall contrast spread",
  "^ remove literal white/light assumptions where shared tokens can carry the relationship",
  "% preserve each route's character without turning the site into isolated color islands",
 ]
 gates: [#theme_legibility, #shared_surface_coherence, #route_identity]
}

^["parallel_work"]{
