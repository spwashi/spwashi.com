^["intent"]{
 ~#goal: "Tune the shared palette so light and dark themes feel authored at the token level, then soften the loudest route-local overrides so the site reads as one system."
 ~#taste: "layering and expressiveness: preserve route identity while making shared surfaces feel less paper-white and more intentionally related."
}

^["development"]{
