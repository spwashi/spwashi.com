}

^["recursive_improvement"]{
 loop: [
  "? distinguish private local asset state from published campaign canon",
  "< add a local asset register that can survive reloads without using localStorage for image blobs",
  "$ render one screenshot-mode frame that stays legible as a still image",
  "^ let exploration unlock motif choices without hiding baseline utility",
  "% keep the core route readable without JavaScript or customization state",
 ]
