 questions: [#what_is_core_utility, #what_is_rewarded, #what_is_safe_to_store, #what_survives_a_screenshot]
 qualities: [#trust, #legibility, #wonder, #containment]
}

^["risk_model"]{
 hard_failures: ["Images stored as base64 in localStorage exceed quota or block the main thread.", "Screenshot mode cannot be dismissed on mobile.", "Import writes invalid asset metadata that strands blobs."]
 soft_failures: ["Motifs feel arbitrary.", "Players mistake local assets for published campaign canon.", "Prompt helpers over-prescribe Midjourney/Grok style instead of giving useful context."]
 recoveries: ["Use IndexedDB blobs and localStorage ids only.", "Keep a visible exit control and Escape handling.", "Validate imports before writing.", "Make motifs optional and utility-neutral."]
 non_negotiables: ["No external upload.", "No analytics on private assets.", "Baseline frame available before unlocks.", "Contrast and reduced-motion safe."]
}

^["validation"]{
 hypotheses: ["Manual screenshot staging is enough if the frame has stable aspect presets and hidden chrome.", "Exploration rewards can teach site features when they unlock motifs rather than power.", "Prompt text can help external tools without coupling the site to any service."]
 negative_controls: ["Existing local gameplay kit remains usable.", "RPG routes remain readable without JavaScript.", "No image data is written to localStorage."]
 demo_path: ["/play/rpg-wednesday/", "upload image", "assign character", "choose aspect", "enter screenshot mode", "copy prompt", "reload", "export", "clear", "import"]
}

