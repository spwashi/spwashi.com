}

^["recursive_improvement"]{
 loop: [
  "? identify what a table needs during play",
  "< ship one local state panel that works across RPG Wednesday routes",
  "$ expose export/import/clear so local state remains trustworthy",
  "^ register the route feature in body data and PWA cache",
  "% keep the published campaign page readable without the kit",
 ]
