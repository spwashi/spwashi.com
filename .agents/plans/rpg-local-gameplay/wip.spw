^["intent"]{
 ~#goal: "Make RPG Wednesday useful at the table by adding local-only campaign state: scene, party, initiative, clocks, quick notes, and seed material that persists in the current browser."
 ~#taste: "Quiet utility, local trust, progressive enhancement, and no app takeover."
}

^["development"]{
 lane: #gameplay_surface
