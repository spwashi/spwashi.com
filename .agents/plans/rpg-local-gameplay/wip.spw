}

^["risk_model"]{
 hard_failures: ["localStorage unavailable", "invalid imported JSON corrupts state"]
 soft_failures: ["players think notes are public", "textarea autosave feels unreliable", "initiative editing is too slow on mobile"]
 recoveries: ["show storage unavailable status", "validate imports before writing", "autosave on input and update visible saved time"]
 non_negotiables: ["no network sync", "export before destructive clear", "page remains readable without JS"]
}

^["validation"]{
 hypotheses: ["A GM can open any RPG Wednesday page and resume table state from localStorage.", "The kit is usable on mobile without hiding the campaign content."]
 negative_controls: ["Existing route navigation, navigator, console, and static content continue to work."]
 demo_path: ["/play/rpg-wednesday/", "/play/rpg-wednesday/sessions/", "/play/rpg-wednesday/world/", "export", "clear", "import"]
}

