# mobile-runtime-foundation
# Distilled semantics note for mobile-first regions, portable interaction intent,
# shared registers, semantic reflection, and future block/script UI.

#>mobile_runtime_foundation
#:semantics #!surface
#:layer #!pragmatics

^["roots"]{
 @site: ~".spw/site.spw"
 @site_semantics: ~".spw/conventions/site-semantics.spw"
 @surfaces: ~".spw/surfaces.spw"
 @shared: ~"public/js/spw-shared.js"
 @core: ~"public/js/site.js?v=0.0.1"
 @components: ~"public/js/spw-component-semantics.js"
 @navigator: ~"public/js/frame-navigator.js"
 @console: ~"public/js/spw-console.js"
 @css: ~"public/css/style.css?v=0.0.1"
}

^["thesis"]{
 claim: "The next useful runtime abstraction is not page-phase identity. It is a mobile-first surface model in which regions own containment, every operator carries interaction semantics, interaction describes intent rather than device events, visible tools become projections of shared registers, semantic HTML acts as the canonical reflection surface, and wonder arrives through symmetric pivots into clearer structure."
 why: "This keeps metaphor aligned to implementation. A calm public site can still behave like an inspectable cognitive machine if its runtime surfaces are named, queryable, reversible, portable across input modes, truthfully mirrored in the accessibility tree, and safe to keep exploring after a no-op or unavailable interaction."
}

^["page_regions"]{
 definition: "A page region is a named containment zone with one interaction owner, one visibility policy, and one inspect path."
 universal: [
  "masthead - global route and status region",
  "frame-stack - primary reading and traversal region",
  "rail - secondary navigator or inspect region",
  "overlay - temporary summoned region",
  "footer - terminal low-salience region"
 ]
 optional: [
  "local-panel - a mode switch or frame-local lens region",
  "lab-surface - higher-voltage experimental region such as pretext"
 ]
 invariants: [
  "On mobile, exactly one primary region should dominate at a time.",
  "A secondary region must collapse into an overlay or sheet before it steals width from the frame stack.",
  "Every persistent region must have a stable name and an inspect path.",
  "A region is a brace host first: it opens a face, it does not silently sprawl."
 ]
 counterexample: "A permanently visible side panel that remains interactive on narrow screens without a named region contract."
 falsify: "If a route cannot answer which region currently owns primary attention, the model is too vague."
}

^["portable_interaction_intent"]{
 definition: "Portable interaction semantics describe what the user is trying to do, not which hardware event happened first."
 intents: {
  inspect: "Reversible address without commitment. May begin via focus, hover, long-press, or explicit inspect action."
  invoke: "Commit to the target's default action. May begin via tap, click, Enter, or scripted route activation."
  hold: "Persist inspection or summon auxiliary affordances without invoking the default action."
  traverse: "Move among peer items or regions without activating them."
  dismiss: "Release overlay, cast state, or inspection depth."
 }
 rules: [
  "Hover may enrich inspect, but it must never be the only route to inspect.",
  "Click is not a semantic primitive. It is one possible transport for invoke.",
  "Touch-first paths must reveal the same structural address that desktop hover reveals.",
  "Portable interaction should normalize into intent traces, not branch permanently on device class."
 ]
 mapping: {
  ambient: "not yet addressed"
  addressable: "available for inspect or invoke"
  focused: "inspect in progress"
  active: "invoke changed visible local state"
  selected: "invoke changed canonical route or anchor state"
 }
 counterexample: "A component tag or control label that appears only on pointer hover and has no tap, focus, or inspect path."
 falsify: "If a coarse-pointer user cannot reveal the same address information as a fine-pointer user, the semantics are not portable."
}

^["operator_interaction_semantics"]{
 definition: "Every operator token should map to an interaction intent before it maps to a concrete gesture. Some operators act, some inspect, some qualify, some bias projection, and some only become available in specific contexts."
 table: [
  ". baseline -> settle the local member or default lens",
  "# frame -> orient to or inspect a named frame/schema",
  "#: layer -> qualify the interpretive layer or runtime role",
  "^ object -> open or inspect structured content",
  "~ ref -> resolve reference without forced commitment",
  "? probe -> inquire, filter, or reveal exploratory affordances",
  "@ action -> commit a local action or projection",
  "* stream -> connect dynamic/event-like content",
  "& merge -> overlay, compare, or integrate fields",
  "= binding -> name, pin, or categorize a local value",
  "$ meta -> reflect on the medium, trace, or register",
  "% normalize -> compare or adjust salience/scale",
  "! pragma -> apply or inspect runtime force or constraint",
  "> surface -> project into rendered view or surface"
 ]
 invariants: [
  "Operator annotation should expose type, intent, and interaction text.",
  "An operator may be inspect-only in a given context, but it should never be meaning-free.",
  "Unavailable operator behavior should explain absence of target rather than feel like a broken click."
 ]
 counterexample: "An operator chip is visually colored, receives focus, and can be clicked, but no title, label, register, or local response can explain what it means."
 falsify: "If a scan of visible operator tokens finds any token without interaction semantics, the operator contract is incomplete."
}

^["ux_machine"]{
 definition: "An effective cognitive machine is a surface that helps a user notice structure, form a reversible hypothesis, act on it, and see the consequence in an inspectable way."
 stages: [
  "orientation - know where attention currently lives",
  "inspection - reveal latent structure without commitment",
  "invocation - commit to a structural move",
  "reflection - project the consequence into a visible register",
  "pivot - enter a deeper structure without losing the prior frame"
 ]
 invariants: [
  "The default state should be calm enough that inspection feels intentional.",
  "Every deep move should have a reversible path and a visible consequence.",
  "Reflection surfaces should tell the truth about runtime state rather than reenacting it approximately."
 ]
 counterexample: "A UI that offers many animated moves but gives no inspectable account of what changed or how to undo it."
 falsify: "If a user can trigger depth but cannot answer what moved, what opened, or how to dismiss it, the machine is not cognitively effective."
}

^["prefix_postfix_symmetry"]{
definition: "Prefix/postfix symmetry means the grammar can be entered from either direction: intent then target (prefix) or target then available intent (postfix), with both paths reducing to the same semantic trace."
prefix_path: "Keyboard-friendly cast or primer model: select operator family first, then choose target."
postfix_path: "Touch- and inspection-friendly path: address a target first, then reveal the transforms or operators that apply to it."
 invariants: [
  "Prefix and postfix paths should write the same register facts for equivalent outcomes.",
  "A target that exposes postfix affordances should also be reachable through a prefix cast when the grammar supports it.",
  "Symmetry does not require identical gestures; it requires semantic equivalence."
 ]
 counterexample: "A long-press sheet exposes actions that cannot be reached through the keyboard grammar, or a keyboard cast can target structures that touch users can never inspect."
 falsify: "If replaying a prefix and postfix path yields different register histories for the same user-visible result, the symmetry is false."
}

^["reflection_symmetry"]{
 definition: "Reflection symmetry means the visible runtime, the interaction grammar, and the semantic HTML/accessibility tree tell the same story about what is present, open, focused, active, or selected."
 forms: [
  "interaction symmetry - prefix and postfix paths reduce to the same semantic trace",
  "spatial symmetry - mirrored or rotated layouts preserve the same interaction meaning where symmetry is claimed",
  "semantic reflection - landmarks, headings, labels, and state-bearing controls mirror runtime truth"
 ]
 invariants: [
  "A visible pivot should have an equally truthful semantic reflection in HTML state.",
  "A surface claimed as mirrored should preserve parity for touch, keyboard, and assistive technology paths.",
  "Reflection is not decorative duplication; it is the same fact projected into another semantic medium."
 ]
 counterexample: "A panel appears open visually, but the owning control does not expose the right expanded state, label, or relationship in the accessibility tree."
 falsify: "If a screen-reader user and a visual user would derive different active structure from the same state, reflection symmetry is broken."
}

^["html_accessibility_structures"]{
 definition: "Native HTML accessibility structures are the primary semantic hosts of cognitive surfaces on the web. They are not fallback markup; they are the canonical reflection surface."
 landmarks: [
  "header/nav/main/article/section/aside/footer for region identity and hierarchy",
  "h1-h6 for local naming and recursive orientation",
  "figure/figcaption for framed illustrations and diagrams",
  "ul/ol/li and table/caption/th for enumerable or matrix-like knowledge surfaces"
 ]
 controls: [
  "a and button as primary invoke hosts",
  "details/summary for inline expansion when it remains local",
  "dialog or popover-backed structures for summoned pivots with explicit ownership and dismissal",
  "fieldset/legend, label/input/output for inspectable control surfaces"
 ]
 rules: [
  "Prefer native semantics first; use ARIA to clarify, not to re-author what HTML already knows.",
  "Every region should have a landmark or an accessible naming path.",
  "Every pivot should expose owner, title, state, and dismissal in semantic HTML.",
  "If a visual projection introduces information not present in the DOM tree, provide a truthful semantic mirror."
 ]
 counterexample: "A visually rich lens or widget whose state is only discoverable by hovering or by reading generated SVG nodes with no semantic host in the page structure."
 falsify: "If removing CSS leaves the page structurally incoherent or if assistive technology cannot recover the same hierarchy and state, the semantic host contract is too weak."
}

^["register_runtime"]{
definition: "A register is a named runtime surface that records state as queryable structure rather than ad hoc module-local memory."
required: [
  "region register - which region owns primary attention, which are secondary, which are latent",
  "focus register - which component is being inspected, invoked, or held",
  "route register - current page, frame, and hash selection",
  "projection register - what navigator, console, and future mirrors are currently projecting"
 ]
 rules: [
  "Navigator and console should read shared registers rather than synthesize incompatible private state.",
  "Any visible inspect surface should be derivable from registers already present in the runtime.",
  "A register may be projected in multiple surfaces, but it should have one runtime owner."
 ]
 inspectability: [
  "A human should be able to answer what the active frame is, what region owns attention, and why a surface is visible without reading multiple modules.",
  "A future spell or mirror should subscribe to registers, not patch page-local DOM assumptions.",
  "Registers should be rich enough to normalize both prefix and postfix interaction traces."
 ]
 counterexample: "Navigator route state and console action history drifting apart because each module infers its own model from DOM events."
 falsify: "If two inspect surfaces disagree about current active state, the register boundary is wrong or missing."
}

^["fractal_surface_geometry"]{
 definition: "Fractal surface geometry means the site's cognitive surfaces repeat the same structural logic across scales: page, region, frame, panel, widget, and node each behave like locally bounded chambers with names, boundaries, inspect paths, pivots, and returns."
 scale_ladder: [
  "page -> named route-scale chamber",
  "region -> major containment and ownership zone",
  "frame -> primary addressable unit",
  "panel or lens -> local sub-chamber or reflective face",
  "widget -> bounded instrument or projection host",
  "node -> smallest inspectable target"
 ]
 invariants: [
  "Each scale should have a boundary, a name, an inspect path, an action path, and a return path.",
  "Learning the grammar at one scale should help predict the next smaller or larger scale.",
  "Fractal here means recursive structure, not visual ornament or literal fractal rendering."
 ]
 counterexample: "A widget whose interaction model, naming, and escape path bear no relation to the frame or region that contains it."
 falsify: "If users must relearn a different grammar at each depth level, the recursive model is metaphor only and not doing cognitive work."
}

^["brace_physics_and_pivots"]{
definition: "Brace physics governs how a surface opens a face to attention; a pivot is a reversible reorganization into a new local structure while preserving the originating address."
rules: [
  "On mobile, one opened brace face should dominate per region stack.",
  "A pivot should preserve origin, current target, and dismissal path.",
  "Nested structure should feel like entering a local chamber, not teleporting into an unrelated page."
 ]
 examples: [
  "frame -> local panel sheet",
  "component -> inspect lens",
  "page -> deeper block-backed surface without losing parent route identity"
 ]
 counterexample: "Tapping a component silently replaces the whole page or opens a floating panel with no visible relation to the originating structure."
 falsify: "If a user cannot name what opened from what, or if dismissal cannot restore the prior brace stack, the pivot contract is broken."
}

^["charge_and_bias_projection"]{
 definition: "A charged brace stores an inspectable tendency that can bias later projection, attention, or pivot choice without removing alternative paths."
 charge_sources: [
  "focus dwell",
  "held inspection",
  "explicit binding",
  "operator sequence",
  "recent projection"
 ]
 bias_rules: [
  "Charge may prefer a lens, surface, or pivot when depth is requested.",
  "Bias should be visible through inspect state, register trace, or local explanation.",
  "Charge should decay, transfer, or discharge; hidden permanent preference is not allowed.",
  "Projection bias may reorder salience but should not make other valid interactions unreachable."
 ]
 counterexample: "A user unknowingly accumulates hidden charge on a frame and later clicks a neutral control that opens an unexpected projection with no inspectable cause."
 falsify: "If projection choice changes because of stored state that cannot be inspected or reset, the charge model is too magical and must be removed or exposed."
}

^["exploration_safety"]{
 definition: "An unavailable or no-op interaction must preserve the user's ability to continue exploring the rest of the field."
 allowed_outcomes: [
  "invoke - visible or semantic state commits",
  "inspect - address or structure becomes clearer",
  "unavailable - absence of target is explained",
  "pass-through - no local effect, no trapped state"
 ]
 invariants: [
  "A click or tap should not leave the runtime in a blocked cast, trapped focus, or half-open pivot.",
  "A no-op should keep neighboring operator paths and frame traversal intact.",
  "Repeated no-response interactions should be diagnosable, not demoralizing."
 ]
 counterexample: "The visitor taps a sigil, nothing happens, focus is lost, and the surrounding operator grammar now feels inert or unsafe to explore."
 falsify: "If a no-response path suppresses later exploration or leaves state inconsistent, it is a bug even when no feature was meant to fire."
}

^["blocks_and_scripts"]{
definition: "A block is a declarative UI object with named inputs, stable identity, and inspectable state. A script is an explicitly hosted behavior bound to a block or region with a visible lifecycle."
preparation: [
  "Give blocks stable ids, roles, and host regions before giving them a richer language surface.",
  "Ensure the semantic HTML mirror exists before richer visual or scripted projections are layered on.",
  "Treat scripts as hosted behaviors with mount, update, and dispose boundaries, not arbitrary inline mutation.",
  "Keep the browser runtime separate from the full Spw parser. The near-term goal is a host contract, not language execution."
]
 host_contract: {
  block: "stable identity, semantic kind, inspect label, mount target, data inputs"
  script: "declared owner, lifecycle hooks, allowed effects, register writes"
 }
 authoring_ladder: [
  "static route with semantic annotations",
  "region-aware route with shared registers",
  "block-hosted component with inspect surface",
  "script-backed component writing through registers",
  "page assembled from Spw-backed blocks and region pivots"
 ]
 counterexample: "An inline script mutates a frame subtree without a named owner, inspect path, or cleanup boundary."
 falsify: "If a future UI script cannot state which block or region it belongs to, the host contract is incomplete."
}

^["wonder"]{
 definition: "Wonder is the felt surplus that appears when a user discovers a deeper structure while remaining oriented within the current one."
 rules: [
  "Wonder should be rare, structural, and inspectable.",
  "A wonder moment should reveal a new relation, not merely a new effect.",
  "Calm defaults make wonder legible; constant stimulation erases it."
 ]
 counterexample: "Permanent animated chrome or ornamental motion that draws attention without teaching a deeper grammar."
 falsify: "If removing a visual flourish leaves the user with the same structural insight, the flourish was decoration, not wonder."
}

^["implementation_order"]{
 1: "Name regions in markup, give them native landmark or naming reflection, and expose region reads from shared runtime helpers."
 2: "Introduce a semantic keyboard dispatcher and portable interaction intent as a thin translation layer above raw DOM events."
 3: "Normalize prefix/postfix and visual/semantic reflection paths into shared registers, then refactor navigator and console into honest projections."
 4: "Prepare page, block, and script host contracts once region, register, and semantic reflection ownership are stable."
 5: "Add wonder surfaces only when pivots, inspectability, and semantic reflection already tell the truth."
}

^["non_goals"]{
 items: [
  "Do not ship a full in-browser Spw parser to prove this model.",
  "Do not add persistent chrome just to make the runtime feel deeper.",
  "Do not let desktop hover semantics define the primary abstraction."
 ]
}
