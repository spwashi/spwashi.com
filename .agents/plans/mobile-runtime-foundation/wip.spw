^["intent"]{
 ~#goal: "Define a mobile-first runtime model for page regions, portable interaction semantics, inspectable registers, semantic reflection, and future block/script UI so implementation can stay calm, coherent, and capable of producing structural wonder."
 ~#taste: "clarity, containment, mobile-first learnability, semantic reflection, and earned wonder"
}

^["development"]{
 lane: #execution_truth
 ladder: #service
 develops: [#semantics, #runtime, #interaction_design]
 review_surfaces: [@plan, @artifact, @semantics]
 snippet_routes: [#example, #query, #spec]
}

^["concept_index"]{
 primary: [#page_regions, #portable_interaction, #operator_interaction_semantics, #register_runtime, #block_ui, #script_ui, #prefix_postfix_symmetry, #reflection_symmetry, #html_landmarks, #fractal_surface_geometry, #brace_physics, #charge_bias, #pivots]
