}

^["recursive_improvement"]{
 loop: [
  "? reread the local semantic grammar before inventing new metaphors",
  "< name one runtime boundary at a time",
  "$ record the invariant and the counterexample together",
  "^ require every operator to expose interaction intent before behavior",
  "^ make the semantic mirror as truthful as the visual surface",
  "^ make each surface inspectable before making it magical",
  "% keep charge and bias inspectable or remove them",
  "% preserve calm defaults while deepening the implementation surface",
  "& require prefix/postfix and visual/semantic reflection paths to collapse into one semantic account"
 ]
 gates: [#claim_discipline, #mobile_truth, #inspectability, #symmetry_truth]
}

^["parallel_work"]{
