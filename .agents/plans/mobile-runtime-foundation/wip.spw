}

^["interaction_depth"]{
 subjects: [#navigation, #inspection, #portable_input, #containment, #mobile_regions, #pivots, #wonder, #semantic_reflection, #fractal_scale, #charge_bias, #no_dead_end_interaction]
 questions: [#what_is_primary, #what_is_reversible, #what_is_visible]
