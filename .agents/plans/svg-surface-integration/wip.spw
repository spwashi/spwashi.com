^["intent"]{
 ~#goal: "Define how SVG widgets, illustrations, and interactive components should enter the site as mobile-first, inspectable, brace-aware surfaces that can later support Spw-backed components and pages."
 ~#taste: "diagrammatic warmth, inspectable restraint, and structural wonder without ornamental noise"
}

