^["intent"]{
 ~#goal: "Make the site navigable as a cognitive space by developing liminality as a traversable depth axis, Spw breadcrumbs as cognitive path projection, spells as learnable named sequences, and accessibility as the canonical cognitive map — creating a tool for artists and practitioners who want to deepen into a surface over time."
 ~#taste: "cognitive cartography, earned fluency, and a site that feels like a place you can get better at inhabiting"
}

^["development"]{
 lane: #execution_truth
 ladder: #service
 develops: [#liminality_navigation, #breadcrumbs, #spell_foundation, #state_components, #filetype_taxonomy, #accessibility_as_map]
 review_surfaces: [@plan, @artifact, @semantics, @runtime_plan, @screenshot_plan]
}

^["concept_index"]{
 primary: [#liminality_navigation, #cognitive_breadcrumb, #spell, #filetype_component, #state_component, #accessibility_map, #depth_traversal]
 surfaces: [#entry, #threshold, #settled, #nested, #projected, #deep, #navigator, #console, #landmark]
 tensions: [#breadcrumb_vs_url_history, #spell_discoverability, #liminality_reversibility, #a11y_as_afterthought, #filetype_complexity]
