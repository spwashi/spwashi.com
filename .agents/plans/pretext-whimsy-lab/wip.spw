^["intent"]{
 ~#goal: "Define a bounded Pretext whimsy lab that turns honest layout data into playful, inspectable mobile-first physics surfaces and seeds later SVG widgets or Spw-backed pages."
 ~#taste: "measured delight, legible force, and structural wonder grounded in real line metrics"
}

