#>asset_metadata
#:layer #!design

^"spirit"{
  whimsy_name: "constellation-dot-5"
  description: "Point in the spatial field, position 5 in the arc"
  visual_qualities: "punctate, positional, sparse"
}

^"thematic_mapping"{
  operator: "probe"
  role: "constellation-marker"
  context: "home-frame overlay"
}

^"usage"{
  surface: "home"
  role: "constellation-overlay"
  dimensions: { width: 64, height: 64 }
  formats_available: ["png"]
  alt_text: "Constellation point 5"
}

^"discovery"{
  tags: ["constellation", "dot", "positional", "arc", "point"]
  part_of: "home-constellation"
  sequence: 5
}
